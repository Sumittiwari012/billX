<UserControl x:Class="MyWPFCRUDApp.Views.PurchaseViews"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MyWPFCRUDApp.Views"
             mc:Ignorable="d" 
             d:DesignHeight="750" d:DesignWidth="1100"
             Background="#F8F9FA">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10" BorderBrush="#DEE2E6" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="1.5*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="5,0">
                    <Label Content="Supplier*" FontSize="11" FontWeight="Bold"/>
                    <DockPanel>
                        <Button Content="+ New" Command="{Binding OpenAddSupplierCommand}" DockPanel.Dock="Right" Padding="10,0" Margin="5,0,0,0"/>
                        <ComboBox ItemsSource="{Binding Suppliers}" 
                                  SelectedItem="{Binding SelectedSupplier}"
                                  DisplayMemberPath="SupplierName" Height="32" VerticalContentAlignment="Center"/>
                    </DockPanel>
                    <TextBlock Text="Tax Mode: Auto-calculating based on GSTIN" Foreground="#6C757D" FontSize="10" Margin="2,5,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="5,0">
                    <Label Content="Invoice Number*" FontSize="11" FontWeight="Bold"/>
                    <TextBox Text="{Binding PurchaseMaster.InvoiceNumber, UpdateSourceTrigger=PropertyChanged}" Height="32" VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="5,0">
                    <Label Content="Purchase Date" FontSize="11" FontWeight="Bold"/>
                    <DatePicker SelectedDate="{Binding PurchaseMaster.PurchaseDate}" Height="32" Width="130"/>
                </StackPanel>

                <Border Grid.Column="3" Margin="20,0,5,0" Background="#E7F5FF" Padding="10" CornerRadius="5">
                    <StackPanel>
                        <Label Content="SCAN BARCODE / SEARCH CODE" Foreground="#1971C2" FontWeight="ExtraBold" FontSize="10"/>
                        <TextBox x:Name="SearchBox" Height="32" BorderBrush="#A5D8FF" BorderThickness="2" VerticalContentAlignment="Center">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" 
                    Command="{Binding BarcodeSearchCommand}" 
                    CommandParameter="{Binding ElementName=SearchBox, Path=Text}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        

        <GroupBox Header="Invoice Items" Grid.Row="2" Background="White">
            <DataGrid ItemsSource="{Binding PurchaseItems}" AutoGenerateColumns="False" IsReadOnly="True" AlternatingRowBackground="#F8F9FA" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E9ECEF">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=Header}" Width="40"/>
                    <DataGridTextColumn Header="Product Name" Binding="{Binding Product.ProductName}" Width="*"/>
                    <DataGridTextColumn Header="Barcode" Binding="{Binding Product.Barcode}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontFamily" Value="Consolas"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Price" Binding="{Binding PurchasePrice, StringFormat={}{0:C}}" Width="100"/>
                    <DataGridTextColumn Header="Qty" 
                    Binding="{Binding Quantity}" 
                    Width="70"/>

                    <DataGridTextColumn Header="CGST %" Binding="{Binding Product.CGST, StringFormat={}{0}%}" Width="70"/>
                    <DataGridTextColumn Header="SGST %" Binding="{Binding Product.SGST, StringFormat={}{0}%}" Width="70"/>
                    <DataGridTextColumn Header="IGST %" Binding="{Binding Product.IGST, StringFormat={}{0}%}" Width="70"/>

                    <DataGridTextColumn Header="Net Amount" Binding="{Binding AfterTaxation, StringFormat={}{0:C}}" Width="130">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="#1971C2"/>
                                <Setter Property="TextAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Header="Action" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Remove" 
                    Command="{Binding DataContext.PurchaseDeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                    CommandParameter="{Binding}" 
                    Background="Transparent" 
                    BorderThickness="0" 
                    Foreground="#E03131" 
                    Cursor="Hand"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <Border Grid.Row="3" Background="#F1F3F5" CornerRadius="0,0,8,8" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Margin="0,0,20,0">
                        <Label Content="Remarks" FontSize="11" FontWeight="Bold"/>
                        <TextBox Text="{Binding PurchaseMaster.Remarks}" Width="250" Height="28"/>
                    </StackPanel>
                    <Button Content="Clear Form" Command="{Binding PurchaseResetCommand}" Width="100" Height="30" VerticalAlignment="Bottom" Background="White"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <StackPanel Margin="0,0,30,0" VerticalAlignment="Center">
                        <Label Content="Discount" HorizontalAlignment="Right" FontSize="11"/>
                        <TextBox Text="{Binding PurchaseMaster.Discount, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" Width="100" Height="28" TextAlignment="Right"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,20,0">
                        <Label Content="GRAND TOTAL" HorizontalAlignment="Right" FontSize="11" FontWeight="Bold" Foreground="#495057"/>
                        <TextBlock Text="{Binding PurchaseMaster.TotalAmount, StringFormat={}{0:C}}" 
                                   FontSize="28" FontWeight="ExtraBold" Foreground="#1971C2" TextAlignment="Right"/>
                    </StackPanel>

                    <Button Content="SAVE INVOICE" Command="{Binding PurchaseSaveCommand}" 
                            Width="180" Height="50" Background="#1971C2" Foreground="White" 
                            FontSize="16" FontWeight="Bold" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>