<Window x:Class="MyWPFCRUDApp.Views.AddSupplierWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MyWPFCRUDApp.Views"
        mc:Ignorable="d"
        Title="AddSupplierWindow" Height="450" Width="800">
    <Grid>
        <StackPanel Margin="20">
            <Label Content="Supplier Name*"/>
            <TextBox x:Name="TxtName" Margin="0,0,0,10" Height="28"/>
            <Label Content="Mobile Number*"/>
            <TextBox x:Name="TxtMobile" Margin="0,0,0,10" Height="28"/>
            <Label Content="GSTIN"/>
            <TextBox x:Name="TxtGST" Margin="0,0,0,10" Height="28"/>
            <Button Content="Save Supplier" Click="Save_Click" Height="35" Background="#2F9E44" Foreground="White" FontWeight="Bold"/>
        </StackPanel>

    </Grid>
</Window>
