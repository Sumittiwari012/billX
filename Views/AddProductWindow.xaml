<Window x:Class="MyWPFCRUDApp.Views.AddProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Register New Product" Height="700" Width="550" 
        WindowStartupLocation="CenterOwner" Background="#F1F3F5">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="Basic Identity" Margin="0,0,0,10" Padding="10" Background="White">
                    <StackPanel>
                        <Label Content="Barcode (Scanned)"/>
                        <TextBox x:Name="TxtBarcode" IsReadOnly="True" Background="#E9ECEF" Height="28" Margin="0,0,0,10" VerticalContentAlignment="Center"/>

                        <Label Content="Product Name*"/>
                        <TextBox x:Name="TxtName" Height="28" Margin="0,0,0,10" VerticalContentAlignment="Center"/>

                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,5,0">
                                <ComboBox x:Name="ComboCategory" 
          DisplayMemberPath="CategoryName" 
          SelectedValuePath="Id" 
          Height="28"
          SelectionChanged="ComboCategory_SelectionChanged"/>
                                <ComboBox x:Name="ComboSubCategory" 
          DisplayMemberPath="SubCategoryName" 
          SelectedValuePath="Id" 
          Height="28"/>
                            </StackPanel>
                            
                            <StackPanel Margin="5,0,0,0">
                                <Label Content="Unit*"/>
                                <ComboBox x:Name="ComboUnit" DisplayMemberPath="UnitName" SelectedValuePath="Id" Height="28"/>
                            </StackPanel>
                        </UniformGrid>

                        <Label Content="HSN Code" Margin="0,10,0,0"/>
                        <TextBox x:Name="TxtHSN" Height="28" VerticalContentAlignment="Center"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Pricing &amp; Taxation" Margin="0,0,0,10" Padding="10" Background="White">
                    <StackPanel>
                        <UniformGrid Columns="3">
                            <StackPanel Margin="0,0,5,0">
                                <Label Content="Purchase Price*"/>
                                <TextBox x:Name="TxtPurchasePrice" Height="28" VerticalContentAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Margin="5,0,5,0">
                                <Label Content="MRP*"/>
                                <TextBox x:Name="TxtMRP" Height="28" VerticalContentAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Margin="5,0,0,0">
                                <Label Content="Sale Price"/>
                                <TextBox x:Name="TxtSalePrice" Height="28" VerticalContentAlignment="Center"/>
                            </StackPanel>
                        </UniformGrid>

                        <Border Background="#E7F5FF" Padding="10" CornerRadius="5" Margin="0,15,0,0">
                            <StackPanel>
                                <Label Content="TAX DETAILS (%)" FontWeight="Bold" Foreground="#1971C2" FontSize="10"/>
                                <UniformGrid Columns="3">
                                    <StackPanel Margin="2">
                                        <Label Content="CGST"/>
                                        <TextBox x:Name="TxtCGST" Text="0" VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Margin="2">
                                        <Label Content="SGST"/>
                                        <TextBox x:Name="TxtSGST" Text="0" VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Margin="2">
                                        <Label Content="CESS"/>
                                        <TextBox x:Name="TxtCESS" Text="0" VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                </UniformGrid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Inventory &amp; Specs" Margin="0,0,0,10" Padding="10" Background="White">
                    <UniformGrid Columns="2">
                        <StackPanel Margin="0,0,5,0">
                            <Label Content="Godown Location"/>
                            <TextBox x:Name="TxtGodown" Height="28" VerticalContentAlignment="Center" Margin="0,0,0,10"/>
                            <Label Content="Rack Number"/>
                            <TextBox x:Name="TxtRack" Height="28" VerticalContentAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Margin="5,0,0,0">
                            <Label Content="Size"/>
                            <TextBox x:Name="TxtSize" Height="28" VerticalContentAlignment="Center" Margin="0,0,0,10"/>
                            <Label Content="Colour"/>
                            <TextBox x:Name="TxtColour" Height="28" VerticalContentAlignment="Center"/>
                        </StackPanel>
                    </UniformGrid>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Cancel" IsCancel="True" Width="80" Height="35" Margin="0,0,10,0"/>
            <Button Content="Save &amp; Add to Invoice" Click="Save_Click" Width="180" Height="40" 
                    Background="#2F9E44" Foreground="White" FontWeight="Bold">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>