<Window x:Class="WpfMySqlCrud.PasswordInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Set MySQL Root Password"
        Height="400" Width="380"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow">

    <StackPanel Margin="20">
        <TextBlock Text="Enter a password for the MySQL root account:"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8"/>

        <PasswordBox x:Name="pwdBox"
                     Height="30"
                     Padding="4"
                     FontSize="13"
                     Margin="0,0,0,6"/>

        <PasswordBox x:Name="pwdConfirmBox"
                     Height="30"
                     Padding="4"
                     FontSize="13"
                     Margin="0,0,0,4"/>

        <TextBlock x:Name="txtHint"
                   Text="Confirm password"
                   Foreground="Gray"
                   FontSize="11"
                   Margin="0,0,0,12"/>

        <Button Content="OK"
                Height="32"
                FontSize="13"
                Background="#27ae60"
                Foreground="White"
                Click="BtnOk_Click"/>
    </StackPanel>
</Window>