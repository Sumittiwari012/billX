<UserControl x:Class="MyWPFCRUDApp.Views.CategoryControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:MyWPFCRUDApp.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.DataContext>
        <vm:CategoryViewModel />
    </UserControl.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Category Input -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <Label Content="Category Name:"
                   VerticalAlignment="Center"
                   FontSize="16"
                   FontWeight="SemiBold"/>

            <TextBox Grid.Column="1"
         Padding="6"
         Margin="4"
         FontSize="16"
         Height="35"
         Text="{Binding CategoryName, UpdateSourceTrigger=PropertyChanged}">

                <TextBox.InputBindings>
                    <KeyBinding Key="Enter"
                    Command="{Binding AddCommand}" />
                </TextBox.InputBindings>

            </TextBox>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,0,0,15"
                    HorizontalAlignment="Center">

            <Button Content="➕ Add"
                    Width="120"
                    Height="38"
                    FontSize="15"
                    Margin="0,0,10,0"
                    Command="{Binding AddCommand}"
                    Background="#27ae60"
                    Foreground="White"/>

            <Button Content="✏️ Update"
                    Width="120"
                    Height="38"
                    FontSize="15"
                    Margin="0,0,10,0"
                    Command="{Binding UpdateCommand}"
                    Background="#2980b9"
                    Foreground="White"/>

            <Button Content="🗑️ Delete"
                    Width="120"
                    Height="38"
                    FontSize="15"
                    Margin="0,0,10,0"
                    Command="{Binding DeleteCommand}"
                    Background="#e74c3c"
                    Foreground="White"/>

            <Button Content="🔄 Refresh"
                    Width="120"
                    Height="38"
                    FontSize="15"
                    Command="{Binding RefreshCommand}"
                    Background="#7f8c8d"
                    Foreground="White"/>
        </StackPanel>

        <!-- DataGrid -->
        <Border Grid.Row="2"
                HorizontalAlignment="Center"
                Width="520"
                BorderBrush="#dcdcdc"
                BorderThickness="1"
                CornerRadius="5"
                Padding="5">

            <DataGrid ItemsSource="{Binding Category}"
                      SelectedItem="{Binding SelectedCategory}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      FontSize="16"
                      RowHeight="35"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      AlternatingRowBackground="#f2f2f2"
                      HeadersVisibility="Column">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"
                                        Binding="{Binding Id}"
                                        Width="80"/>
                    <DataGridTextColumn Header="Category Name"
                                        Binding="{Binding CategoryName}"
                                        Width="*"/>
                </DataGrid.Columns>

            </DataGrid>

        </Border>

    </Grid>

</UserControl>