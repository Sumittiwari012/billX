<Window x:Class="MyWPFCRUDApp.Views.ExcelMappingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Map Excel Columns" Height="450" Width="400" 
        WindowStartupLocation="CenterOwner" Background="#F8F9FA">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Link Excel Headers to Product Fields" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Mappings}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" Foreground="#495057"/>
                            <ComboBox Grid.Column="1" 
                                      ItemsSource="{Binding DataContext.ExcelHeaders, RelativeSource={RelativeSource AncestorType=Window}}"
                                      SelectedItem="{Binding SelectedExcelColumn}"
                                      Padding="5"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Cancel" IsCancel="True" Width="80" Height="30" Margin="5"/>
            <Button Content="Import Data" Click="Import_Click" Width="100" Height="30" 
                    Background="#FF1F3A5F" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>