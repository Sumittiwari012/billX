<UserControl x:Class="MyWPFCRUDApp.Views.CompanyInfoViews"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1100"
             Background="White">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <GroupBox Header="Registered Companies" Margin="5">
            <DataGrid ItemsSource="{Binding Companies}" 
                      SelectedItem="{Binding SelectedCompany}" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="40"/>
                    <DataGridTextColumn Header="Company Name" Binding="{Binding CompanyName}" Width="*"/>
                    <DataGridTextColumn Header="City" Binding="{Binding City}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Margin="5">
            <StackPanel>

                <GroupBox Header="Basic Identity" Margin="0,0,0,10">
                    <UniformGrid Columns="2" Margin="5">
                        <StackPanel Margin="5">
                            <Label Content="Company Name*"/>
                            <TextBox Text="{Binding CompanyInfo.CompanyName, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Margin="5">
                            <Label Content="Owner Name"/>
                            <TextBox Text="{Binding CompanyInfo.OwnerName}"/>
                        </StackPanel>
                        <StackPanel Margin="5">
                            <Label Content="Mobile"/>
                            <TextBox Text="{Binding CompanyInfo.Mobile}"/>
                        </StackPanel>
                        <StackPanel Margin="5">
                            <Label Content="Phone"/>
                            <TextBox Text="{Binding CompanyInfo.Phone}"/>
                        </StackPanel>
                        <StackPanel Margin="5">
                            <Label Content="Email"/>
                            <TextBox Text="{Binding CompanyInfo.Email}"/>
                        </StackPanel>
                        <StackPanel Margin="5">
                            <Label Content="Website"/>
                            <TextBox Text="{Binding CompanyInfo.Website}"/>
                        </StackPanel>
                    </UniformGrid>
                </GroupBox>

                <GroupBox Header="Address Details" Margin="0,0,0,10">
                    <StackPanel Margin="5">
                        <Label Content="Address Line 1"/>
                        <TextBox Text="{Binding CompanyInfo.AddressLine1}"/>
                        <Label Content="Address Line 2" Margin="0,5,0,0"/>
                        <TextBox Text="{Binding CompanyInfo.AddressLine2}"/>
                        <UniformGrid Columns="3" Margin="0,5,0,0">
                            <StackPanel Margin="0,0,5,0">
                                <Label Content="City"/>
                                <TextBox Text="{Binding CompanyInfo.City}"/>
                            </StackPanel>
                            <StackPanel Margin="5,0,5,0">
                                <Label Content="State"/>
                                <TextBox Text="{Binding CompanyInfo.State}"/>
                            </StackPanel>
                            <StackPanel Margin="5,0,0,0">
                                <Label Content="Pincode"/>
                                <TextBox Text="{Binding CompanyInfo.Pincode}"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Tax &amp; Registration" Margin="0,0,0,10">
                    <UniformGrid Columns="2" Margin="5">
                        <StackPanel Margin="5">
                            <Label Content="GST Number"/>
                            <TextBox Text="{Binding CompanyInfo.GSTNumber}"/>
                        </StackPanel>
                        <StackPanel Margin="5">
                            <Label Content="PAN Number"/>
                            <TextBox Text="{Binding CompanyInfo.PANNumber}"/>
                        </StackPanel>
                        <StackPanel Margin="5">
                            <Label Content="CIN Number"/>
                            <TextBox Text="{Binding CompanyInfo.CINNumber}"/>
                        </StackPanel>
                        <StackPanel Margin="5">
                            <Label Content="IEC Code"/>
                            <TextBox Text="{Binding CompanyInfo.IECCode}"/>
                        </StackPanel>
                    </UniformGrid>
                </GroupBox>

                <GroupBox Header="Banking Details" Margin="0,0,0,10">
                    <UniformGrid Columns="2" Margin="5">
                        <StackPanel Margin="5">
                            <Label Content="Bank Name"/>
                            <TextBox Text="{Binding CompanyInfo.BankName}"/>
                        </StackPanel>
                        <StackPanel Margin="5">
                            <Label Content="Branch"/>
                            <TextBox Text="{Binding CompanyInfo.Branch}"/>
                        </StackPanel>
                        <StackPanel Margin="5">
                            <Label Content="Account Number"/>
                            <TextBox Text="{Binding CompanyInfo.AccountNumber}"/>
                        </StackPanel>
                        <StackPanel Margin="5">
                            <Label Content="IFSC Code"/>
                            <TextBox Text="{Binding CompanyInfo.IFSCCode}"/>
                        </StackPanel>
                    </UniformGrid>
                </GroupBox>

                <GroupBox Header="Invoice Settings" Margin="0,0,0,10">
                    <StackPanel Margin="5">
                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,10,0">
                                <Label Content="Invoice Start Number"/>
                                <TextBox Text="{Binding CompanyInfo.InvoiceStartNumber}"/>
                            </StackPanel>
                            <CheckBox Content="Show Logo on Invoice" 
                                      IsChecked="{Binding CompanyInfo.ShowLogoOnInvoice}" 
                                      VerticalAlignment="Center" Margin="0,20,0,0"/>
                        </UniformGrid>

                        <Label Content="Logo Path" Margin="0,5,0,0"/>
                        <TextBox Text="{Binding CompanyInfo.LogoPath}"/>

                        <Label Content="Invoice Footer Note" Margin="0,5,0,0"/>
                        <TextBox Text="{Binding CompanyInfo.InvoiceFooterNote}" Height="50" TextWrapping="Wrap" AcceptsReturn="True"/>
                    </StackPanel>
                </GroupBox>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,5,20">
                    <Button Content="Reset" Command="{Binding ResetCommand}" Width="90" Height="30" Margin="5"/>
                    <Button Content="Delete" Command="{Binding DeleteCommand}" Width="90" Height="30" Margin="5" Background="#FFFFEBEB" Foreground="DarkRed"/>
                    <Button Content="Save Company" Command="{Binding SaveCommand}" Width="130" Height="30" Margin="5" Background="#FF007ACC" Foreground="White" FontWeight="Bold"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>