<Window x:Class="WpfMySqlCrud.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Student CRUD" Height="520" Width="680"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Form fields -->
            <RowDefinition Height="Auto"/>
            <!-- Buttons     -->
            <RowDefinition Height="*"/>
            <!-- DataGrid    -->
        </Grid.RowDefinitions>

        <!-- ── INPUT FORM ── -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Label Content="Student's Name:"  Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
            <TextBox x:Name="txtName"  Grid.Row="0" Grid.Column="1" Margin="4,8,16,8" Padding="4"/>

            <Label Content="Age:"   Grid.Row="0" Grid.Column="2" VerticalAlignment="Center"/>
            <TextBox x:Name="txtAge"   Grid.Row="0" Grid.Column="3" Margin="0,4,0,4"  Padding="4"/>

            <Label Content="Email:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
            <TextBox x:Name="txtEmail" Grid.Row="1" Grid.Column="1" Margin="0,4,12,4"
                     Padding="4" Grid.ColumnSpan="3"/>
        </Grid>

        <!-- ── ACTION BUTTONS ── -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="➕ Add"    Width="100" Margin="0,0,8,0" Padding="6"
                    Click="BtnAdd_Click"    Background="#27ae60" Foreground="White"/>
            <Button Content="✏️ Update" Width="100" Margin="0,0,8,0" Padding="6"
                    Click="BtnUpdate_Click" Background="#2980b9" Foreground="White"/>
            <Button Content="🗑️ Delete" Width="100" Margin="0,0,8,0" Padding="6"
                    Click="BtnDelete_Click" Background="#e74c3c" Foreground="White"/>
            <Button Content="🔄 Refresh" Width="100" Padding="6"
                    Click="BtnRefresh_Click" Background="#8e44ad" Foreground="White"/>
        </StackPanel>

        <!-- ── DATA GRID ── -->
        <DataGrid x:Name="dgStudents" Grid.Row="2"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionChanged="DgStudents_SelectionChanged"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#f2f2f2"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"    Binding="{Binding Id}"    Width="50"/>
                <DataGridTextColumn Header="Name"  Binding="{Binding Name}"  Width="*"/>
                <DataGridTextColumn Header="Age"   Binding="{Binding Age}"   Width="60"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}"  Width="2*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>